generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            UserRole  @default(CUSTOMER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  uploads       Upload[]
  orders        Order[]
  refreshTokens RefreshToken[]
  draftDesigns  DraftDesign[]
  cart          Cart?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Upload {
  id               String       @id @default(uuid())
  userId           String
  s3Key            String       @unique
  s3Bucket         String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  status           UploadStatus @default(PENDING)
  zone             PrintZone
  validatedAt      DateTime?
  createdAt        DateTime     @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mockups    Mockup[]
  orderItems OrderItem[]

  @@map("uploads")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  basePrice   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants     ProductVariant[]
  draftDesigns DraftDesign[]

  @@map("products")
}

model ProductVariant {
  id              String      @id @default(uuid())
  productId       String
  color           String
  colorHex        String
  size            String
  additionalPrice Int         @default(0)
  stockStatus     StockStatus @default(AVAILABLE)
  createdAt       DateTime    @default(now())

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  draftDesigns DraftDesign[]
  cartItems    CartItem[]

  @@unique([productId, color, size])
  @@map("product_variants")
}

model Order {
  id              String      @id @default(uuid())
  userId          String?     // null for guest orders
  guestId         String?     // guest session ID (from X-Guest-Id header)
  guestEmail      String?     // collected at checkout for guest tracking/notifications
  status          OrderStatus @default(DRAFT)
  subtotal        Int
  total           Int
  currency        String      @default("ARS")
  shippingAddress Json
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user     User?       @relation(fields: [userId], references: [id])
  items    OrderItem[]
  payment  Payment?
  printJob PrintJob?

  @@index([guestId])
  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id               String  @id @default(uuid())
  orderId          String
  productVariantId String
  uploadId         String?
  quantity         Int
  unitPrice        Int
  customizations   Json?

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  upload         Upload?        @relation(fields: [uploadId], references: [id])

  @@map("order_items")
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String        @unique
  provider          String        @default("MERCADOPAGO")
  providerPaymentId String?       @unique
  status            PaymentStatus @default(PENDING)
  amount            Int
  currency          String        @default("ARS")
  providerResponse  Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Mockup {
  id          String       @id @default(uuid())
  uploadId    String
  s3Key       String?
  status      MockupStatus @default(QUEUED)
  generatedAt DateTime?
  createdAt   DateTime     @default(now())

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@map("mockups")
}

model PrintJob {
  id             String    @id @default(uuid())
  orderId        String    @unique
  status         JobStatus @default(PENDING)
  trackingNumber String?
  trackingUrl    String?
  submittedAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("print_jobs")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum UploadStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum PrintZone {
  FRONT
  BACK
  TAG
}

enum MockupStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PAID
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum StockStatus {
  AVAILABLE
  OUT_OF_STOCK
}

enum JobStatus {
  PENDING
  SUBMITTED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum DraftStatus {
  ACTIVE
  CONVERTED
  EXPIRED
}

model DraftDesign {
  id        String      @id @default(uuid())
  guestId   String?
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product        @relation(fields: [productId], references: [id])
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int            @default(1)

  // Canvas state per zone: { FRONT?: Layer[], BACK?: Layer[], TAG?: Layer[] }
  zonesData Json @default("{}")

  // Confirmed upload IDs per zone: { FRONT?: uploadId, BACK?: uploadId, TAG?: uploadId }
  uploadIds Json @default("{}")

  previewS3Key String?

  status    DraftStatus @default(ACTIVE)
  expiresAt DateTime?   // null for auth'd users; 30 days for guests

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartItems CartItem[]

  @@index([guestId, status])
  @@index([userId, status])
  @@index([productId])
  @@index([expiresAt])

  @@map("draft_designs")
}

model Cart {
  id      String  @id @default(uuid())
  guestId String? @unique
  userId  String? @unique
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items CartItem[]

  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([guestId])
  @@index([userId])

  @@map("carts")
}

model CartItem {
  id     String @id @default(uuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  draftDesignId String?
  draftDesign   DraftDesign? @relation(fields: [draftDesignId], references: [id])

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int

  // Snapshot for display; always re-validated at checkout (ARS cents)
  unitPriceSnapshot Int

  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cart_items")
}